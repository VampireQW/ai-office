# AI办公室 环境配置
# 复制此文件为 .env 并填入真实值

# LLM 配置（必填，支持任何 OpenAI 兼容格式的服务商）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-llm-provider.com/v1
LLM_MODEL=your-model-name
LLM_MAX_OUTPUT_TOKENS=16000
LLM_TIMEOUT_SECONDS=600
LLM_MAX_IMAGES=4
AIKY_CONTEXT_MAX_IMAGE_BYTES=8388608

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
